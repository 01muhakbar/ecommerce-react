# Client build/runtime config
#
# The main API client uses same-origin /api. Put a reverse proxy in front of
# the client/backend for production, or update the API client strategy in a
# separate planned task.

# Used by upload/static asset URL resolution when the API/static server is not
# the same origin as the client app.
VITE_SERVER_ORIGIN=http://localhost:3001

# Legacy httpClient only. Prefer same-origin /api via client/src/api/axios.ts.
VITE_API_BASE_URL=/api

# Dev-server proxy target only.
VITE_PROXY_API_HOST=localhost
VITE_PROXY_API_PORT=3001
