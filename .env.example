# Server
NODE_ENV=development
PORT=3001

# Opsi PROXY (disarankan) -> tidak perlu CORS_ORIGIN
# Opsi CROSS-ORIGIN -> isi origin FE:
# CORS_ORIGIN=http://localhost:5173
# CLIENT_URL=http://localhost:5173

# Auth
JWT_SECRET=change_me_to_a_strong_secret
AUTH_COOKIE_NAME=token
# Production: omit COOKIE_SECURE to auto-secure cookies, or set true explicitly.
# Only use false for local HTTP development/proof runs.
COOKIE_SECURE=false

# DB (pilih salah satu)
# DATABASE_URL=mysql://user:pass@localhost:3306/ecommerce_dev
# DB_SYNC=false # enable only for fresh dev DB
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce_dev
DB_USER=root
DB_PASS=your_password

# Uploads
# Keep writable on the target host/container. Server also serves this directory as /uploads.
UPLOAD_DIR=uploads

# Client
# Main client API uses same-origin /api. VITE_API_BASE_URL is legacy-only.
# Set VITE_SERVER_ORIGIN to the production API/static origin when the client is hosted separately.
VITE_API_BASE_URL=/api
VITE_SERVER_ORIGIN=http://localhost:3001

# Public checkout origin for hosted redirects.
# Set at least one explicit base URL for staging/public beta when Stripe checkout is enabled.
# PUBLIC_BASE_URL=http://localhost:5173
# CLIENT_PUBLIC_BASE_URL=http://localhost:5173
# STORE_PUBLIC_BASE_URL=http://localhost:5173

# Multistore shipment rollout flags.
# Set both flags explicitly for staging/public beta.
# ENABLE_MULTISTORE_SHIPMENT_MVP=true
# ENABLE_MULTISTORE_SHIPMENT_MUTATION=false
# VITE_ENABLE_MULTISTORE_SHIPMENT_MVP=true
# VITE_ENABLE_MULTISTORE_SHIPMENT_MUTATION=false

# Optional email delivery
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your_user
# EMAIL_PASS=your_password
# EMAIL_FROM=TP PRENEURS <no-reply@example.com>
#
# Gmail example:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
# EMAIL_USER=your_gmail@gmail.com
# EMAIL_PASS=your_16_char_app_password
# EMAIL_FROM=TP PRENEURS <your_gmail@gmail.com>

# Client registration verification
# CLIENT_REGISTRATION_OTP_EXPIRY_MS=600000
# CLIENT_REGISTRATION_OTP_RESEND_COOLDOWN_MS=60000
# CLIENT_REGISTRATION_OTP_MAX_ATTEMPTS=5
# CLIENT_REGISTRATION_OTP_MAX_RESENDS=5
# CLIENT_REGISTRATION_MIN_SUBMIT_DELAY_MS=4000

# Seeder
SUPER_ADMIN_EMAIL=admin@local
SUPER_ADMIN_PASSWORD=admin123

# Public release smoke gate
# PUBLIC_RELEASE_SMOKE_PORT=3025
# PUBLIC_RELEASE_SMOKE_SKIP_BUILD=false
# PUBLIC_RELEASE_SMOKE_SKIP_APP_SMOKES=false
# Optional: use a dedicated release/test DB env file instead of local dev DB.
# See docs/public-release-env.md and .env.public-release.example.
# PUBLIC_RELEASE_SMOKE_ENV_FILE=.env.public-release
