# Copy to .env.public-release and fill with staging/test credentials.
# Do not commit the copied file.

NODE_ENV=production
PORT=3025

# Auth
JWT_SECRET=replace_with_at_least_24_random_characters
AUTH_COOKIE_NAME=token
COOKIE_SECURE=false

# Database: prefer DATABASE_URL, or fill all DB_* values below.
# DATABASE_URL=mysql://public_release_user:replace_password@localhost:3306/ecommerce_public_release
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce_public_release
DB_USER=public_release_user
DB_PASS=replace_password

# Local/same-origin proof URLs. Use real HTTPS origins for staging.
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:5173

# Writable upload directory for the smoke server process.
UPLOAD_DIR=uploads

# Public release smoke options.
PUBLIC_RELEASE_SMOKE_PORT=3025
PUBLIC_RELEASE_SMOKE_SKIP_BUILD=false
PUBLIC_RELEASE_SMOKE_SKIP_APP_SMOKES=false
