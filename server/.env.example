NODE_ENV=development
PORT=3001

# Allowed client origins for CORS
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Auth cookie + JWT (dev-only sample values)
JWT_SECRET=change_me_in_local_dev
AUTH_COOKIE_NAME=token
COOKIE_SECURE=false

# Database (use either DATABASE_URL OR split DB_* variables)
# DATABASE_URL=mysql://root:@localhost:3306/ecommerce_dev
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=ecommerce_dev

# Optional: model sync at startup (dev only)
DB_SYNC=false

# Optional: seed credentials used by some seed scripts
SEED_SUPER_EMAIL=superadmin@local.dev
SEED_SUPER_PASS=supersecure123
