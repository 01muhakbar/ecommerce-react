NODE_ENV=development
PORT=3001

# Allowed client origins for CORS
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Auth cookie + JWT (dev-only sample values)
JWT_SECRET=change_me_in_local_dev
AUTH_COOKIE_NAME=token
# Set true for staging/public beta when auth cookies cross HTTPS boundaries.
COOKIE_SECURE=false

# Database (use either DATABASE_URL OR split DB_* variables)
# DATABASE_URL=mysql://root:@localhost:3306/ecommerce_dev
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=ecommerce_dev

# Optional: model sync at startup (dev only)
DB_SYNC=false

# Uploads
# Keep writable on the target host/container.
UPLOAD_DIR=uploads

# Public checkout origin for hosted redirects.
# Set at least one explicit base URL for staging/public beta when Stripe checkout is enabled.
# PUBLIC_BASE_URL=http://localhost:5173
# CLIENT_PUBLIC_BASE_URL=http://localhost:5173
# STORE_PUBLIC_BASE_URL=http://localhost:5173

# Multistore shipment rollout flags.
# Set both flags explicitly for staging/public beta.
# ENABLE_MULTISTORE_SHIPMENT_MVP=true
# ENABLE_MULTISTORE_SHIPMENT_MUTATION=false

# Optional: seed credentials used by some seed scripts
SEED_SUPER_EMAIL=superadmin@local.dev
SEED_SUPER_PASS=supersecure123
